pipeline {
    agent { label 'local' } 

    environment {
        DOCKER_HUB_USER = 'gautamkathuria'
        IMAGE_NAME      = 'myhtmltestapp'
        DOCKER_CREDS    = 'docker-hub-creds'
        GIT_URL         = 'git@github.com:Gautamkathuria/test-html.git'
    }

    stages {
        stage('Clone Repository') {
            steps {
                git credentialsId: 'github-auth', 
                    url: "${GIT_URL}", 
                    branch: 'main'
            }
        }

        stage('Build & Push Image') {
            steps {
                echo "Building Image version ${env.BUILD_ID}..."
                
                // Tagging with build number helps in rollbacks
                sh "docker build -t ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest ."
              
                
                withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDS}", 
                                                 passwordVariable: 'PASS', 
                                                 usernameVariable: 'USER')]) {
                    sh "echo ${PASS} | docker login -u ${USER} --password-stdin"
                    sh "docker push ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
    
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo 'Deploying directly from Localhost Node...'
                
                // Since we are ON the host, we use local kubectl context automatically
                sh """
                    # Ensure we are using the right cluster context
                    kubectl config use-context kind-gautam-cluster
                    
                    # Apply changes
                    kubectl apply -f deployment.yaml
                    
                    # Force the 3 workers to pull the new image
                    kubectl rollout restart deployment/myhtml-app
                    kubectl rollout status deployment/myhtml-app
                """
            }
        }
    }

    post {
        always {
            echo 'Cleaning up local environment...'
            sh 'docker logout'
            // Clean up the specific build tag to save space, keep 'latest'
            sh "docker rmi ${DOCKER_HUB_USER}/${IMAGE_NAME}:${env.BUILD_ID} || true"
        }
        success {
            echo 'Deployment Successful on Local-Node!'
        }
    }
}
