# ========================= Atlas CLI ==============================================
# install atlas cli
Ubuntu/Debian
curl -fsSL https://pgp.mongodb.com/atlas-cli.asc | sudo gpg --dearmor -o /usr/share/keyrings/mongodb-atlas-cli.gpg
echo "deb [signed-by=/usr/share/keyrings/mongodb-atlas-cli.gpg] https://repo.mongodb.com/apt/ubuntu jammy/mongodb-atlas-cli multiverse" | sudo tee /etc/apt/sources.list.d/mongodb-atlas-cli.list
sudo apt-get update
sudo apt-get install -y mongodb-atlas-cli

# verify installation
atlas --version
# Login
atlas auth login
# Login with API keys
atlas auth login --publicKey <public-key> --privateKey <private-key>
# Check who is logged in
atlas auth whoami
# Logout
atlas auth logout
# Register new account
atlas auth register


# Initialize configuration
atlas config init
# List configuration
atlas config list
# Set default project
atlas config set project_id <project-id>
# Set output format (json or plaintext)
atlas config set output json
atlas config set output plaintext
# Describe current config
atlas config describe name 


# List all projects
atlas projects list
# Create a project
atlas projects create <project-name>
# Describe a project
atlas projects describe <project-id>
# Delete a project
atlas projects delete <project-id>
# List users in a project
atlas projects users list
# Invite user to project
atlas projects invitations invite <email> --role GROUP_OWNER

# List organizations
atlas organizations list
# Describe organization
atlas organizations describe <org-id>
# List users in organization
atlas organizations users list
# Invite user to organization
atlas organizations invitations invite <email> --role ORG_OWNER


# List all clusters
atlas clusters list
# Describe a cluster
atlas clusters describe <cluster-name>
# Get connection strings
atlas clusters connectionStrings describe <cluster-name>
# Watch cluster status
atlas clusters watch <cluster-name>

# Create M10 cluster (paid)
atlas clusters create <cluster-name> \
  --provider AWS \
  --region US_EAST_1 \
  --tier M10 \
  --diskSizeGB 10
# Create M0 (free tier) - must use web interface

# Pause a cluster
atlas clusters pause <cluster-name>
# Resume a cluster
atlas clusters start <cluster-name>
# Delete a cluster
atlas clusters delete <cluster-name>
# Delete with force (no confirmation)
atlas clusters delete <cluster-name> --force
# Update cluster
atlas clusters update <cluster-name> --tier M20
# Upgrade cluster
atlas clusters upgrade <cluster-name>

# List all database users
atlas dbusers list
# Create a database user
atlas dbusers create \
  --username <username> \
  --password <password> \
  --role <role>
# Create user with specific database access
atlas dbusers create \
  --username myuser \
  --password Pass123 \
  --role readWrite@mydatabase
# Create admin user
atlas dbusers create \
  --username admin \
  --password AdminPass123 \
  --role atlasAdmin
# Create user with multiple roles
atlas dbusers create \
  --username multiuser \
  --password Pass123 \
  --role readWrite@db1 \
  --role read@db2
# Update user password
atlas dbusers update <username> --password <new-password>
# Update user role
atlas dbusers update <username> --role atlasAdmin
# Delete a user
atlas dbusers delete <username>
# Delete user without confirmation
atlas dbusers delete <username> --force
# Describe a user
atlas dbusers describe <username>

# common roles:
--role read@<database>                # Read-only
--role readWrite@<database>           # Read and write
--role readAnyDatabase                # Read all databases
--role readWriteAnyDatabase           # Read/write all databases
--role dbAdmin@<database>             # Database admin
--role atlasAdmin                     # Full cluster admin



# List all access lists
atlas accessLists list
# Add current IP to whitelist
atlas accessLists create --currentIp
# Add specific IP
atlas accessLists create --ip <ip-address>
# Add IP with comment
atlas accessLists create --ip 192.168.1.100 --comment "Office IP"
# Add IP range (CIDR)
atlas accessLists create --cidr 192.168.1.0/24
# Add CIDR with comment
atlas accessLists create --cidr 192.168.1.0/24 --comment "Office Network"
# Allow access from anywhere (not recommended)
atlas accessLists create --cidr 0.0.0.0/0 --comment "Public Access"
# Delete an IP
atlas accessLists delete <ip-address>
# Delete CIDR
atlas accessLists delete <cidr-block>
# Delete without confirmation
atlas accessLists delete <ip-address> --force
# Describe access list entry
atlas accessLists describe <entry-value>


# List snapshots
atlas backups snapshots list <cluster-name>
# Create a snapshot
atlas backups snapshots create <cluster-name>
# Create snapshot with description
atlas backups snapshots create <cluster-name> \
  --desc "Before production deployment"
# Describe a snapshot
atlas backups snapshots describe <cluster-name> <snapshot-id>
# Delete a snapshot
atlas backups snapshots delete <cluster-name> <snapshot-id>
# Watch snapshot creation
atlas backups snapshots watch <cluster-name> <snapshot-id>


# List teams
atlas teams list
# Create a team
atlas teams create <team-name>
# Describe a team
atlas teams describe <team-id>
# Delete a team
atlas teams delete <team-id>
# Add user to team
atlas teams users add <team-id> <user-id>
# Remove user from team
atlas teams users delete <team-id> <user-id>