# create a adminer container:
adminer:
    image: adminer
    container_name: adminer
    restart: always
    ports:
      - "8084:8080"
    environment:
      ADMINER_DEFAULT_SERVER: mysql_db
    depends_on:
      - mysql_db
      - postgres
    networks:                            # important to add network same as database
      - db_net

# Access adminer GUI at http://localhost:8084
# login with the following details:-
# System: MySQL or PostgreSQL
# Server: mysql_db or postgres
# Username: as per your database user
# Password: as per your database password
# Database: as per your database name




