=============================== share the running container==============================
# to share the running container
# 1. commit the container to an image
docker commit container_id image_name:tag
docker commit container_id image_name 

# save the image as tar file
docker save -o image_name.tar image_name:tag
docker save -o imagename.tar image_name
-o  = output file name
# copy the tar file to another server

1. create a ssh key in local server
ssh-keygen -t rsa -b 4096

2. copy the public key to remote server
ssh-copy-id user@remote_server_ip
or manually copy the id_rsa.pub in the ~/.ssh/authorized_keys file of remote server

3. now change the permissions
chmod 700 ~/.ssh
chmod 600 ~/.ssh/authorized_keys

4. now copy the tar file to remote server
scp image_name.tar user@remote_server_ip:/path/on/remote/server

5. load the image from tar file in remote server
docker load -i image_name.tar
-i = input file name

6. now run the container from the image
docker run -d -p 8080:8080 --name adminer adminer:1.0
docker run -d image_name:tag

docker run -d myapp:1.0


======================= docker limits on resource usage=========================
# limit the cpu usage to 0.5 cpu
docker run -d --name myapp --cpus=".5" myapp
# limit the memory usage to 500mb
docker run -d --name myapp --memory="500m" myapp:1.0
# limit both cpu and memory
docker run -d --name myapp --cpus=".5" --memory="500m" myapp:1.0
# to see the resource usage of container
docker stats
docker compose stats

# to limit resource usage in docker compose file
version: "3.9"
services:
  myapp:
    image: myapp:1.0
    deploy:
      resources:
        limits:
          cpus: "1.0"
          memory: 500M

use this instead of deploy if you are not using swarm mode

services:
  myapp:
    image: myapp:1.0
    cpus: 1.0
    mem_limit: 500m













