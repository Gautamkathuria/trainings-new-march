===========================# docker file structure===================================

FROM --	Base image (required as first line)
WORKDIR --	Directory inside container
COPY --	Copy files from host → container
ADD	-- Like COPY but can extract archives & download
RUN --	Execute commands in build time
CMD --	Default command when container starts
ENTRYPOINT --	Main command container always runs
ENV --	Set environment variables
EXPOSE --	Document port (not required but useful)
USER --	Switch to a user
VOLUME --	Declare mount point

# to build image from docker file
docker build -t myapp .

