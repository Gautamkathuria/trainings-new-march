==============================now create nginx-ingress with certbot ssl===============================

# create a namespace
kubectl create namespace nginx-ingress
# now create a nginx-ingress deployment with service of type loadbalancer
kubectl apply -f nginx-ingress-controller.yaml
# now check the service to get the load balancer dns
kubectl get svc -n nginx-ingress
# now create a record in route53 to point to the load balancer dns
# now create a certbot deployment to get ssl certs from letsencrypt
kubectl apply -f certbot-deployment.yaml
# now create a certbot cronjob to renew the certs
kubectl apply -f certbot-cronjob.yaml
# now create a nginx ingress resource to route traffic to the nginx ingress controller
kubectl apply -f nginx-ingress-resource.yaml
# now test the nginx ingress with ssl
# now clean up
kubectl delete -f nginx-ingress-resource.yaml
kubectl delete -f certbot-cronjob.yaml
kubectl delete -f certbot-deployment.yaml
kubectl delete -f nginx-ingress-controller.yaml
kubectl delete namespace nginx-ingress


