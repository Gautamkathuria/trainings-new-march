# to create a grafana container write docker compose file:
services:
  grafana:
    image: grafana/grafana-enterprise
    container_name: grafana
    restart: always
    env_file:
      - ./.env/grafana.env
    ports:
      - "3000:3000"
    volumes:
      - ./grafana_data:/var/lib/grafana
      - ./grafana.ini:/etc/grafana/grafana.ini //commented if using env file
    networks:
      - monitoring_net
networks:
  monitoring_net:
    driver: bridge

# create .env/grafana.env file to store environment variables:
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# chmod -R 776 grafana_data

