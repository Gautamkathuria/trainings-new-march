================================ jenkins ecr push ==================================
pipeline {
  agent { label 'worker' }

  environment {
    AWS_ACCOUNT_ID = '460068713582'
    AWS_REGION = 'us-east-1'
    APP_NAME = 'admin'
    IMAGE_TAG = "${APP_NAME}-${BUILD_NUMBER}"
    ECR_REPO = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/production/${APP_NAME}"
    FULL_IMAGE_TAG = "${ECR_REPO}:${IMAGE_TAG}"
    GIT_CRED_ID = 'backend'
    GIT_URL = 'git@github.com:Cert-Digital/crd-token-backend.git'
    BRANCH = 'main'
    K8S_NAMESPACE = 'production'
    DEPLOYMENT_NAME = 'admin'
    CONTAINER_NAME = 'admin'
    ENV_DIR = "/opt/docker/jenkins-server/.files/backend"
    DOCKER_FILENAME = "Dockerfile.admin"
  }

  stages {
    stage('Clean Workspace') {
      steps {
        cleanWs()
      }
    }

    stage('Clone Repository') {
      steps {
        git branch: "${BRANCH}", url: "${GIT_URL}", credentialsId: "${GIT_CRED_ID}"
        //sh "git checkout be043dc18dd9af22dbb6d62fa2408558f58c783c"
        }
    }

    stage('Add Environment Files') {
      steps {
          sh "sudo cp ${ENV_DIR}/.env .env"
          sh "sudo cp ${ENV_DIR}/${DOCKER_FILENAME} ."
        }
    }

    stage('Build Docker Image') {
      steps {
        script {
          sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REPO}"
          sh "docker build -f ${DOCKER_FILENAME} -t ${FULL_IMAGE_TAG} . --no-cache"
          }
      }
    }

    stage('Push to ECR') {
      steps {
        sh "docker push ${FULL_IMAGE_TAG}"
        sh "docker system prune --volumes -af"
      }
    }

    stage('Deploy to EKS') {
      steps {
        script {
          try {
            sh "kubectl set image deployment/${DEPLOYMENT_NAME} ${CONTAINER_NAME}=${FULL_IMAGE_TAG} -n ${K8S_NAMESPACE} "
            sh "kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=120s"
            echo "✅ Rollout successful."
          } catch (e) {
            echo "❌ Rollout failed. Triggering rollback..."
            sh "kubectl rollout undo deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}"
            error("Deployment failed and was rolled back.")
          }
        }
      }
    }
  }

  post {
    always {
      cleanWs()
    }
  }
}








