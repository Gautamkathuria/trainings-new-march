pipeline {
    agent any 

    environment {
        DOCKER_HUB_USER = 'gautamkathuria'
        IMAGE_NAME      = 'myhtmltestapp'
        DOCKER_CREDS    = 'docker-hub-creds' 
        K8S_CREDS       = 'k8s_config'       
        // We point directly to the KinD Control Plane container name
        // This bypasses the need for the host IP 172.17.0.1
        K8S_SERVER      = 'https://gautam-cluster-control-plane:6443'
    }

    stages {
        stage('Clone Repository') {
            steps {
                git credentialsId: 'github-auth', 
                    url: "git@github.com:Gautamkathuria/test-html.git", 
                    branch: 'main'
            }
        }

        stage('Build & Push Image') {
            steps {
                echo 'Building Image...'
                // Using BUILD_NUMBER ensures you don't keep overwriting the same tag
                sh "docker build -t ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest ."
                
                withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDS}", 
                                                 passwordVariable: 'PASS', 
                                                 usernameVariable: 'USER')]) {
                    sh "echo ${PASS} | docker login -u ${USER} --password-stdin"
                    sh "docker push ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo 'Deploying to KinD Cluster via Kubernetes CLI Plugin...'
                
                // withKubeConfig is provided by the Kubernetes CLI Plugin
                // It allows us to override the server URL without changing the file
                withKubeConfig(credentialsId: "${K8S_CREDS}", serverUrl: "${K8S_SERVER}") {
                    
                    sh """
                        # 1. Force kubectl to ignore the certificate block inside your config
                        kubectl config set-cluster kind-gautam-cluster --insecure-skip-tls-verify=true
                        
                        # 2. Deploy using the updated context
                        kubectl apply -f deployment.yaml
                        
                        # 3. Force pull newest image and wait for rollout across the 3 worker nodes
                        kubectl rollout restart deployment/myhtml-app
                        kubectl rollout status deployment/myhtml-app
                    """
                }
            }
        }
    }

    post {
        always {
            echo 'Cleaning up local environment...'
            sh 'docker logout'
            sh 'docker image prune -f'
        }
        success {
            echo 'Deployment Successful! Your app is running on 1 Master + 3 Worker nodes.'
        
        }
    }
}

