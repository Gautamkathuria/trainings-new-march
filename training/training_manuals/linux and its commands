# users :- 
types :- root, system, normal
# UID = user identifier
UID 0 = reserved for root
UID 1 - 999= system account used by services
UID 1000+ = regular users
# UID and users stored in  cat etc/passwd

# groups :-
types :- primary, secondary
# GID = group identifier
GID 0 = root
GID 1-99 = system groups
GID 100-999 = service/system groups
GID 1000+ = Regular user group
GID 65534 = nobody group 
# GID and groups stored in  cat etc/group


