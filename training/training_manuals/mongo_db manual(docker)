 # create GUI based mongo client using docker (mongo-express)

 mongoexpress:
    image: mongo-express:latest
    container_name: mongoexpress
    restart: unless-stopped
    env_file:
      - ./.env/mongoexpress.env
    ports:
      - "8081:8081"
    depends_on:
      - mongo_db
    networks:
      - db_net
# create a .env/mongoexpress.env file to store mongo-express environment variables
ME_CONFIG_MONGODB_SERVER=mongo_db

ME_CONFIG_BASICAUTH_USERNAME=admin //commented
ME_CONFIG_BASICAUTH_PASSWORD=pass  //commented

ME_CONFIG_MONGODB_AUTH_USERNAME=readonly
ME_CONFIG_MONGODB_AUTH_PASSWORD=readonly123
ME_CONFIG_MONGODB_AUTH_DATABASE=mydb
ME_CONFIG_MONGODB_ENABLE_ADMIN=false

Or

# Mongo Express UI authentication
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=pass

# MongoDB connection string
ME_CONFIG_MONGODB_URL=mongodb://root:example@mongo_db:27017/?authSource=admin

# Optional (recommended)
ME_CONFIG_MONGODB_ENABLE_ADMIN=false





