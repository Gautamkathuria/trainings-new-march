# MongoDB specific docker commands
docker compose exec mongo_db bash
docker compose logs -f mongo_db
docker compose exec mongo_db mongosh -u root -p

# for normal connection use the following connection string
mongodb://readuser:read@localhost:27017/mydatabase
mongodb://root:example@localhost:27017/admin
mongodb://root:example@mongo_db:27017/admin


# for remote connection use the following connection string
mongodb://readuser:read@<remote_host_ip>:27017/mydatabase    # Or our pvt ip

# for docker compose use the following connection string in your application
MONGO_URI=mongodb://writeuser:write@mongo_db:27017/student?authSource=student 

# to set up a mongodb container using docker compose
services:
  mongo_db:
    image: mongo:6
    container_name: mongodb
    restart: always
    env_file:
      - ./.env/mongo.env 
    ports:
      - "27017:27017"
    volumes:
      - ./mongo_data:/var/lib/mongo
    networks:
      - db_net
networks:
  db_net:
    driver: bridge

# Save the above content in a file named docker-compose.yml
# Then create a .env/mongo.env file to store mongo environment variables
MONGO_INITDB_ROOT_USERNAME: root
MONGO_INITDB_ROOT_PASSWORD: example

# Finally run the docker compose up command to start mongodb container
docker-compose up -d
# To access mongodb container run the following command
docker exec -it <container_name> mongosh -u user_name -p
#replace <container_name> with mongo_db and user_name with root
sudo docker compose exec mongo_db mongosh -u root -p
# Replace example with your desired root password.

#show dbs
show dbs;
#use a specific db
use mydatabase;
#create a collection
db.createCollection("mycollection");
#insert a document into the collection
db.mycollection.insertOne({name: "John Doe", age: 30});
#find documents in the collection
db.mycollection.find();
# to see all collections in the current database
show collections;
# to delete a collection
db.mycollection.drop();
# to create a user with specific roles
use admin
db.createUser({
  user: "myUserAdmin",
  password: "abc123",
  roles: [ { role: "userAdminAnyDatabase", db: "admin" } ]
})
# create user for a specific database
db.createUser({user: "mydbuser",pwd: "password",roles: [{ role: "read", db: "mydb" }]})

# to see all users in the current database
show users;

# to delete a user
use mydatabase
db.dropUser("mydbuser");

#to delete a database
use mydatabase
db.dropDatabase();

#to login with a specific user using docker compose exec
sudo docker compose exec mongo_db
mongosh -u mydbuser -p --authenticationDatabase mydb

#to take a backup of all databases
docker exec -it <container_name> mongodump --out /tmp/backup
sudo docker compose exec mongo_db mongodump -u root -p example --authenticationDatabase admin
# to take a backup of a specific database
sudo docker compose exec mongo_db mongodump -u root -p example --authenticationDatabase admin -d mydb --out /backup
# replace <container_name> with mongo_db
# to restore a backup to a specific database
docker exec -it <container_name> mongorestore --db mydatabase /tmp/backup/mydatabase
# replace <container_name> with mongo_db

#to restore a specific database from backup within container
mongorestore \
  --authenticationDatabase admin \
  -u root -p example \
  --db mydb2 \
  --drop \
  /backup/mydb

#to create a backup of databases on host machine within container
mongodump \
  --authenticationDatabase admin \
  -u root -p example \
  --db mydb \
  --out /backup


mongodump \
  --authenticationDatabase admin \
  -u root -p example \
  --out /backup/all-databases

mongodump --authenticationDatabase admin -u lern-devadmin -p guire99jkd874ui --db lern360-dev --out /backup/lern360-dev

# now copy the backup from remote server to local machine
scp user@remote_host:/path/to/backup -r /local/path/to/backup

# steps to download backup from remote to local machine
# 1. SSH into remote server
ssh user@remote_host
# 2. Navigate to the directory where backup is stored
cd /path/to/backup
# 3. Use scp command to copy backup to local machine(for mongodb also)
scp -r ubuntu@43.204.19.22:/home/ubuntu/project/mysql/sql_bacup /home/gautam/Desktop/project

# 4. Enter password if prompted
# 5. Wait for the transfer to complete
# 6. Verify the backup is copied to local machine

# steps to do ssh into remote server
#create key pair on local machine
ssh-keygen -t rsa -b 2048 or ssh-keygen -t ed25519
#copy public key to remote server
ssh-copy-id user@remote_host 
# or manually copy the content of ~/.ssh/id_rsa.pub to ~/.ssh/authorized_keys on remote server
#now ssh into remote server without password
ssh user@remote_host
# Example command to copy backup from remote server to local machine
scp -i ~/.ssh/id_rsa -r ubuntu@54.153.191.42:/opt/docker/apps/data/backup ~/Downloads/
# make a zip of backup folder on remote server before copying
 zip -r backup.zip backup/

# now transfer the zip file from local machin to remote server
 scp -i ~/.ssh/id_rsa ~/Downloads/backup.zip ubuntu@54.153.191.42 :/opt/docker/apps/data/backup.zip

