# to login mysql thrugh gui tools like phpmyadmin
 phpmyadmin:
    image: phpmyadmin/phpmyadmin:latest
    container_name: phpmyadmin
    restart: unless-stopped
    env_file:
      - ./.env/phpmyadmin.env
    ports:
      - "8082:80"
    networks:
      - db_net
    depends_on:
      - mysql_db

# .env/phpmyadmin.env file content
