# To set up a MySQL database using Docker, you can use the following steps:
# Create a docker-compose.yml file with the following content

version: '3.8'
services:
  mysql_db:
    image: mysql:latest
    restart: always
    env_file:
      - ./.env/mysql.env
    ports:
      - "3306:3306" 
    volumes:
      - sql_data:/var/lib/mysql 
      - ./db_backup:/tmp/db_backup
    networks:
      - db_net
networks:
  db_net:
    driver: bridge
volumes:
  sql_data:
# Save the above content in a file named docker-compose.yml
# Then create a .env/mysql.env file to store mysql environment variables
MYSQL_ROOT_PASSWORD: my-pw
MYSQL_DATABASE: mysqldb

# Finally run the docker compose up command to start mysql container
docker-compose up -d
# To access mysql container run the following command
docker exec -it <container_name> mysql -u user_name -p
#replace <container_name> with mysql_db and user_name with root
sudo docker compose exec mysql_db mysql -u root -p
# Replace my-pw and mysqldb with your desired root password and database name respectively.
# Then run the following command to start the MySQL container
docker-compose up -d  
# To stop the MySQL container, run the following command
docker-compose down
# To access the MySQL container, run the following command
docker exec -it mysql_db mysql -u root -p
#replace mysql_db with your container name if different
