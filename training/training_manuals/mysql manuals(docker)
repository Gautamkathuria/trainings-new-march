# to restore the backup from inside the mysql
SOURCE /tmp/db_backup/schoolbackup.sql 

#to bacup all databases using docker compose
mysqldump -u root -p --all-databases > all_databases_backup.sql
# To back up a MySQL database using Docker, you can use the following command:
sudo docker compose exec mysql_db mysqldump -u root -p dumpdata > ~/Desktop/project/db_backup/back.sql


# This command will create a backup of all databases in a file named all_databases_backup.sql on your host machine.
# To restore a MySQL database from a backup file using Docker, you can use the following command:
cat all_databases_backup.sql | docker exec -i mysql_db sh -c 'mysql -u root -p"$MYSQL_ROOT_PASSWORD"'
# This command will restore the databases from the all_databases_backup.sql file into the MySQL container.
# Make sure to replace mysql_db with your actual container name if it's different.


cat back.sql | sed -e 's/SET @@GLOBAL.GTID_PURGED=.*//g' | sudo docker compose exec -T mysql_db mysql -u root --password=my-pw restore^C
# This command will restore the databases from the back.sql file into the MySQL container.

