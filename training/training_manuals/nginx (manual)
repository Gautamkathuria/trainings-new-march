# types of reverse proxy:-
1. load balancing reverse proxy (upstream server)
2. caching reverse proxy = Serve repeated content from cache
4. security reverse proxy
5. ssl termination reverse proxy
6. global server load balancing reverse proxy
# load balancing reverse proxy example:-
upstream backend_servers {
    server backend1.example.com;
    server backend2.example.com;
    server backend3.example.com;
}
server {
    listen 80;
    server_name example.com;

    location / {
        proxy_pass http://backend_servers;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

# master process and worker process:-
# master process - read and evaluate configuration files, manage worker processes, handle signals
# worker process - handle client requests, perform actual processing of requests

master process run as root user
worker process run as non root user (user www-data)

# default location of nginx files:-
1. main configuration file - /etc/nginx/nginx.conf
2. site-available directory - /etc/nginx/sites-available/
3. site-enabled directory - /etc/nginx/sites-enabled/
4. document root directory - /var/www/html/
5. log files - /var/log/nginx/
6. modules directory - /etc/nginx/modules/
7. mime types file - /etc/nginx/mime.types
8. ssl certificates directory - /etc/nginx/ssl/

# access logs = who requested what and when
/var/log/nginx/access.log
# error logs = errors encountered by nginx
/var/log/nginx/error.log

=========================================Rate limiting in nginx=========================================
# rate limiting in nginx is used to control the rate of incoming requests from clients to prevent abuse and ensure fair usage of server resources.

# to limit the number of requests from a single IP address
http {
    limit_req_zone $binary_remote_addr zone=mylimit:10m rate=5r/s;

    server {
        location / {
            limit_req zone=mylimit burst=10 nodelay;
            proxy_pass http://backend;
        }
    }
}

# limit_req_zone Defines a shared memory zone to track requests.
limit_req_zone $variable zone=name:size rate=rate;

$variable → usually $binary_remote_addr (client IP)
Zone=name:size → memory zone for tracking clients
rate → max requests per second

# limit_req Applies the limit to a location or server.
limit_req zone=name [burst=number] [nodelay];

zone → must match limit_req_zone
burst → allows temporary extra requests
nodelay → processes burst requests immediately (default is delayed)

