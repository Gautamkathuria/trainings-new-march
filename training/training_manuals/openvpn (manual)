https://github.com/kylemanna/docker-openvpn
# to setup openvon in ubuntu:-
cd openvpn
# create a docker compose file:-
version: '3.8'
services:
  openvpn:
    image: kylemanna/openvpn
    container_name: openvpn-server
    cap_add:
      - NET_ADMIN
    ports:
      - "1194:1194/udp"
    volumes:
      - ./openvpn_data:/etc/openvpn
    restart: unless-stopped

# initialize openvpn config:-
docker compose run --rm openvpn ovpn_genconfig -u udp://<your_server_ip>

# to see public ip:-
curl ifconfig.me = to see public ip 
curl ip.me

#  Generate Server Certificates and Keys
docker compose run --rm -it openvpn ovpn_initpki

# start the open vpn server
 docker compose up -d

#  Generate Client Certificates and Configuration
 docker compose run --rm -it openvpn easyrsa build-client-full client1 nopass

# Retrieve Client Configuration:
docker compose run --rm openvpn ovpn_getclient client1 > client1.ovpn

