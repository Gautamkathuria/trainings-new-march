
# Jl
enkinsfile for ssh based git cloning and docker build and running
pipeline{
    agent {label 'linux'}

    stages {
        stage('clone repository') {
            steps {
                echo 'Cloning repository...'
                git credentialsId: 'github-jenkins',
                url: "git@github.com:gautamkathuria-sudo/mypipeline.git"    ,
                branch: 'main'
            }
        }
        stage('build docker image') {
            steps {
                echo 'Building docker image...'
                sh 'docker build -t myapp:latest .'
            }
        }
        stage('build docker container') {
            steps {
                echo 'Building docker container...'
                sh 'docker run -d -p 8081:80 --name myapp_container myapp:latest'
            }
        }
    }
}
