# build with string parameter for branch name
        pipeline {
    agent { label 'linux' }

    parameters {
    string(name: 'branch', defaultValue: 'main', description: 'Enter the branch name')  
 
}

    stages {

        stage('Clone Repository') {
            steps {
                echo "Selected branch: ${params.branch}"
                echo 'Cloning repository...'

                git(
                    branch: "${params.branch}",
                    credentialsId: 'github-jenkins',
                    url: "git@github.com:gautamkathuria-sudo/mypipeline.git"
                )
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image...'
                sh 'docker build -t buildparam:latest .'
            }
        }

        stage('Run Docker Container') {
            steps {
                echo 'Running Docker container...'
                sh 'docker rm -f buildparam_container || true'
                sh 'docker run -d -p 8083:80 --name buildparam_container buildparam:latest'
            }
        }
    }
}


# pipline to show the logs of selected docker container
pipeline {
    agent { label 'linux' }
    parameters {
        choice(
            name: 'container_name',
            choices: ['myapp_container', 'buildparam_container'],
            description: 'Select the Docker container to view logs'
        )
    stages {
        stage('View Docker Logs') {
            steps {
                echo "Fetching logs for container: ${params.container_name}"
                sh "docker logs ${params.container_name}"
            }
        }
    }


}}

# create a pipeline that clean space remove unused docker images and containers
pipeline {
    agent { label 'linux' }
    stages {
        stage('Clean Docker Space') {
            steps {
                echo 'Cleaning up unused Docker images and containers...'
                sh 'docker system prune -f'
            }
        }
    }
