# now create a jenkins pipeline to scan code using sonarqube
pipeline {
    agent any

    stages {  
        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Gautamkathuria/html.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'sonar-scanner'
                    withSonarQubeEnv('SonarQube') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                          -Dsonar.projectKey=samplewebapp \
                          -Dsonar.sources=.
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 60, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
}
# now run the jenkins pipeline
# after the pipeline is successful go to sonarqube dashboard to see the code analysis report