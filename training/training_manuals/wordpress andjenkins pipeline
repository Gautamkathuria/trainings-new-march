# create a wordpress container we need database to store the files data 
# here is the compose file for wordpress and db

services:
  db:
    image: mysql:8.0
    container_name: wp-db
    restart: always
    env_file: ./.env/mysql.env
    volumes:
      - ./db_data:/var/lib/mysql
    networks:
      - wp-network

  wordpress:
    image: wordpress:php8.2-apache
    container_name: wp-app
    restart: always
    ports:
      - "8081:80"
    env_file: ./.env/wordpress.env
    volumes:
      - ./wp_data:/var/www/html
    depends_on:
      - db
    networks:
      - wp-network
networks:
    wp-network:
        driver: bridge

# create a .env folder and inside it create two files mysql.env and wordpress.env
# mysql.env
MYSQL_DATABASE=mydb
MYSQL_USER=admin
MYSQL_PASSWORD=password123
MYSQL_ROOT_PASSWORD=password
# wordpress.env
WORDPRESS_DB_HOST=db
WORDPRESS_DB_NAME=wp_prod
WORDPRESS_DB_USER=admin
WORDPRESS_DB_PASSWORD=password123

# now run the compose file
docker compose up -d
# now you can access the wordpress setup on localhost:8081

