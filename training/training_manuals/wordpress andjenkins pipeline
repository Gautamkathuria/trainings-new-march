=======================================backup and restore wordpress database=======================================
# to backup the wordpress database we need to access the mysql container
docker exec -it wp-db bash
# now run the following command to backup the database
mysqldump -u admin -p wp_prod > /backup/wp_prod_backup.sql
# now copy the backup file to host machine
docker cp wp-db:/backup/wp_prod_backup.sql ./wp_prod_backup.sql
# now to restore the database we need to copy the backup file to mysql container
docker cp ./wp_prod_backup.sql wp-db:/backup/wp_prod_backup.sql
# now access the mysql container
docker exec -it wp-db bash
# now run the following command to restore the database
mysql -u admin -p wp_prod < /backup/wp_prod_backup.sql
# now exit
# exit




